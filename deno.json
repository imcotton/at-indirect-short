{
  "$schema": "https://raw.esm.sh/gh/denoland/deno@v2.7.8/cli/schemas/config-file.v1.json",
  "name": "@indirect/short",
  "version": "1.5.0",
  "license": "AGPL-3.0-only",
  "lock": false,
  "imports": {
    "@hono/valibot-validator": "jsr:@hono/valibot-validator@~0.6.1",
    "@std/cache": "jsr:@std/cache@~0.2.2",
    "@std/crypto": "jsr:@std/crypto@1",
    "@std/encoding": "jsr:@std/encoding@1",
    "@std/text": "jsr:@std/text@^1.0.17",
    "@std/uuid": "jsr:@std/uuid@1",
    "fnv1a": "npm:@sindresorhus/fnv1a@3.1.0",
    "hono": "jsr:@hono/hono@^4.12.9",
    "qr": "jsr:@paulmillr/qr@~0.5.5",
    "valibot": "jsr:@valibot/valibot@^1.3.1"
  },
  "tasks": {
    "dev": "deno serve --port 3000 -N=esm.sh:443 -R=./db -W=./db --watch dev.ts"
  },
  "exports": {
    "./deploy/cloudflare": "./deploy/cloudflare.ts",
    "./deploy/deno": "./deploy/deno.ts",
    "./helper": "./helper.ts",
    "./hotfix": "./hotfix.ts",
    "./app": "./app.tsx",
    ".": "./mod.ts"
  },
  "publish": {
    "include": [
      "./**/*.ts",
      "./**/*.tsx",
      "./LICENSE.txt",
      "./README.md",
      "./deno.json"
    ]
  },
  "test": {
    "include": [
      "./specs"
    ]
  },
  "unstable": [
    "kv"
  ],
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx",
    "jsxImportSourceTypes": "hono/jsx",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true
  }
}
